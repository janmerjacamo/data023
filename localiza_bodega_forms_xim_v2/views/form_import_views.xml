<odoo>
    <record id="view_localiza_forms_import_list" model="ir.ui.view">
        <field name="name">localiza.forms.import.list</field>
        <field name="model">localiza.forms.import</field>
        <field name="arch" type="xml">
            <list string="Importaciones de Formularios">
                <field name="name"/>
                <field name="import_type"/>
                <field name="filename"/>
                <field name="created_count"/>
                <field name="state"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>
    <record id="view_localiza_forms_import_form" model="ir.ui.view">
        <field name="name">localiza.forms.import.form</field>
        <field name="model">localiza.forms.import</field>
        <field name="arch" type="xml">
            <form string="Importacion de Formularios">
                <header>
                    <button name="action_import" type="object" string="Importar archivo" class="btn-primary"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done,error"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <field name="import_type"/>
                        <field name="file" filename="filename"/>
                        <field name="filename"/>
                        <field name="created_count" readonly="1"/>
                    </group>
                    <group>
                        <field name="log" readonly="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_localiza_forms_import" model="ir.actions.act_window">
        <field name="name">Importar Formularios V2</field>
        <field name="res_model">localiza.forms.import</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
