<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_localiza_srm" model="ir.module.category">
        <field name="name">Localiza SRM</field>
        <field name="sequence">25</field>
    </record>

    <record id="group_localiza_comercial" model="res.groups">
        <field name="name">Comercial</field>
        <field name="category_id" ref="module_category_localiza_srm"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_localiza_comercial_manager" model="res.groups">
        <field name="name">Responsable Comercial</field>
        <field name="category_id" ref="module_category_localiza_srm"/>
        <field name="implied_ids" eval="[(4, ref('group_localiza_comercial'))]"/>
    </record>
</odoo>
