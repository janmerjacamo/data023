<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_localiza_articulo_list" model="ir.ui.view">
        <field name="name">localiza.articulo.list</field>
        <field name="model">localiza.articulo</field>
        <field name="arch" type="xml">
            <list string="Artículos Operativos">
                <field name="codigo"/>
                <field name="name"/>
                <field name="categoria"/>
                <field name="subcategoria"/>
                <field name="talla"/>
                <field name="unidad"/>
                <field name="criticidad"/>
                <field name="stock_minimo"/>
                <field name="requiere_serie"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    <record id="view_localiza_articulo_form" model="ir.ui.view">
        <field name="name">localiza.articulo.form</field>
        <field name="model">localiza.articulo</field>
        <field name="arch" type="xml">
            <form string="Artículo Operativo">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="codigo"/>
                            <field name="categoria"/>
                            <field name="subcategoria"/>
                            <field name="product_id"/>
                        </group>
                        <group>
                            <field name="talla"/>
                            <field name="unidad"/>
                            <field name="criticidad"/>
                            <field name="stock_minimo"/>
                            <field name="requiere_serie"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notas"><field name="notes"/></page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_localiza_articulo" model="ir.actions.act_window">
        <field name="name">Artículos Operativos</field>
        <field name="res_model">localiza.articulo</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
