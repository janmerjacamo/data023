<odoo>
    <record id="view_localiza_bodega_dashboard_card_kanban" model="ir.ui.view">
        <field name="name">localiza.bodega.dashboard.card.kanban</field>
        <field name="model">localiza.bodega.dashboard.card</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_dashboard" create="0" edit="0" delete="0">
                <field name="name"/>
                <field name="description"/>
                <field name="total_count"/>
                <field name="pending_count"/>
                <field name="done_count"/>
                <field name="alert_count"/>
                <field name="color"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click o_kanban_card">
                            <div class="o_kanban_card_header">
                                <div class="o_kanban_card_header_title">
                                    <strong><field name="name"/></strong>
                                    <div class="text-muted"><field name="description"/></div>
                                </div>
                            </div>
                            <div class="container o_kanban_card_content mt8">
                                <div class="row text-center">
                                    <div class="col-3"><span class="h2"><field name="total_count"/></span><br/><small>Total</small></div>
                                    <div class="col-3"><span class="h2 text-warning"><field name="pending_count"/></span><br/><small>Pend.</small></div>
                                    <div class="col-3"><span class="h2 text-success"><field name="done_count"/></span><br/><small>OK</small></div>
                                    <div class="col-3"><span class="h2 text-danger"><field name="alert_count"/></span><br/><small>Alertas</small></div>
                                </div>
                            </div>
                            <div class="o_kanban_card_manage_pane mt8">
                                <button type="object" name="action_open" class="btn btn-primary btn-sm">Abrir</button>
                                <button type="object" name="action_open_pending" class="btn btn-secondary btn-sm">Pendientes</button>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <record id="view_localiza_bodega_dashboard_card_list" model="ir.ui.view">
        <field name="name">localiza.bodega.dashboard.card.list</field>
        <field name="model">localiza.bodega.dashboard.card</field>
        <field name="arch" type="xml">
            <list string="Panel Principal">
                <field name="sequence"/>
                <field name="name"/>
                <field name="card_type"/>
                <field name="total_count"/>
                <field name="pending_count"/>
                <field name="done_count"/>
                <field name="alert_count"/>
            </list>
        </field>
    </record>
    <record id="action_localiza_bodega_dashboard_unificado" model="ir.actions.act_window">
        <field name="name">Panel Principal Bodega</field>
        <field name="res_model">localiza.bodega.dashboard.card</field>
        <field name="view_mode">kanban,list</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Panel principal de Bodega Operativa</p>
            <p>Desde aquí se monitorean formularios, entregas, puestos, GPS, inventarios y préstamos.</p>
        </field>
    </record>
</odoo>
